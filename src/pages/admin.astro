          const disabled = disabledValue && g.id === disabledValue && g.id !== selectedValue;
          return `<option value="${g.id}" ${disabled ? 'disabled' : ''}>${g.nom}</option>`;
        }).join('');
    };

    groupASelect.innerHTML = buildGroupeOptions({ selectedValue: selectedA, disabledValue: selectedB });
    groupBSelect.innerHTML = buildGroupeOptions({ selectedValue: selectedB, disabledValue: selectedA });
    groupASelect.value = selectedA;
    groupBSelect.value = selectedB;

    const buildTexteOptions = (items) => {
