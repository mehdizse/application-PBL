        items.map((t) => `<option value="${t.id}">${t.titre}</option>`).join('');
    };

    const textesA = selectedA ? textes.filter((t) => t.groupeId === selectedA) : [];
    const textesB = selectedB ? textes.filter((t) => t.groupeId === selectedB) : [];
    texteASelect.innerHTML = buildTexteOptions(textesA);
    texteBSelect.innerHTML = buildTexteOptions(textesB);
    texteASelect.value = String(winningTeamData?.teams?.a?.texteId || '');
    texteBSelect.value = String(winningTeamData?.teams?.b?.texteId || '');

    const winner = String(winningTeamData?.winner || '');
    const winnerActiveClass = 'bg-amber-50 border-amber-300 text-amber-800';
    const normalClass = 'bg-white border-gray-300 text-gray-700 hover:bg-gray-50';
    winnerBtnA.className = `px-3 py-1.5 rounded-md text-xs font-medium border transition-colors ${winner === 'a' ? winnerActiveClass : normalClass}`;
    winnerBtnB.className = `px-3 py-1.5 rounded-md text-xs font-medium border transition-colors ${winner === 'b' ? winnerActiveClass : normalClass}`;

