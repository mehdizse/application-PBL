  function setWinningTeamStatus(message) {
    const el = document.getElementById('winningTeamStatus');
    if (!el) return;
    el.textContent = message;
  }

  function parseExpressionsInput(rawValue) {
    return String(rawValue ?? '')
      .split('\n')
      .map((line) => line.replace(/^[-*]\s*/, '').trim())
      .filter((line) => line.length > 0);
  }

  const WEEK_ID_REGEX = /^\d{4}-\d{2}$/;
  const ISO_DATE_REGEX = /^\d{4}-\d{2}-\d{2}$/;

  function parseIsoDateStrict(raw) {
    if (!ISO_DATE_REGEX.test(raw)) return null;
    const [year, month, day] = raw.split('-').map(Number);
    const date = new Date(Date.UTC(year, month - 1, day));
    if (
      date.getUTCFullYear() !== year ||
      date.getUTCMonth() !== month - 1 ||
      date.getUTCDate() !== day
    ) {
      return null;
    }
    return date;
  }

  function validateWeeklyForm({ weekId, startDate, endDate, expressions }) {
    if (!WEEK_ID_REGEX.test(weekId)) {
      throw new Error('weekId invalide (attendu YYYY-WW)');
    }

    if (!ISO_DATE_REGEX.test(startDate) || !ISO_DATE_REGEX.test(endDate)) {
      throw new Error('Les dates doivent etre en format YYYY-MM-DD');
    }

    const start = parseIsoDateStrict(startDate);
    const end = parseIsoDateStrict(endDate);
    if (!start || !end) {
      throw new Error('Dates invalides (jour/mois impossible)');
    }

    if (end.getTime() < start.getTime()) {
      throw new Error('La date de fin doit etre apres la date de debut');
    }

    if (!Array.isArray(expressions) || expressions.length === 0) {
      throw new Error('Ajoute au moins une expression');
    }
  }

  function getCurrentWeekFallback() {
    if (typeof window.getIsoWeekInfo === 'function') {
      return window.getIsoWeekInfo(new Date());
    }
    return { weekId: '1970-01', startDate: '1970-01-01', endDate: '1970-01-07' };
  }

  function fillWeeklyForm(week) {
    if (!week) return;
    document.getElementById('weekIdInput').value = week.weekId || '';
    document.getElementById('weekStartInput').value = week.startDate || '';
    document.getElementById('weekEndInput').value = week.endDate || '';
    document.getElementById('defiInput').value = Array.isArray(week.expressions) ? week.expressions.join('\n') : '';
  }

  function renderWeeklyArchives() {
    const container = document.getElementById('defiArchives');
    const archives = weeklyExpressionsData?.archives || [];
    if (archives.length === 0) {
      container.innerHTML = '<p class="text-xs text-gray-500">Aucune archive pour le moment</p>';
      return;
    }

    container.innerHTML = archives.map((week) => `
      <button
        type="button"
        data-week-id="${week.weekId}"
        class="px-3 py-1.5 rounded-full text-xs font-medium border border-gray-200 bg-white hover:bg-gray-50 transition-colors"
      >
        ${week.weekId}
      </button>
    `).join('');

    container.querySelectorAll('button').forEach((button) => {
      button.addEventListener('click', () => {
        const selected = weeklyExpressionsData.weeks.find((week) => week.weekId === button.dataset.weekId);
        fillWeeklyForm(selected);
      });
    });
  }

  async function loadWeeklyExpressions() {
    try {
      weeklyExpressionsData = await window.getWeeklyExpressionsData();
      const container = document.getElementById('defiActuel');
      const currentWeek = weeklyExpressionsData?.currentWeek;

      if (currentWeek) {
        fillWeeklyForm(currentWeek);
        container.innerHTML = `
          <p class="text-sm font-medium text-gray-900 mb-1">Semaine courante: ${currentWeek.weekId}</p>
          <p class="text-xs text-gray-500 mb-2">${currentWeek.startDate} au ${currentWeek.endDate}</p>
          <ul class="space-y-1">
            ${currentWeek.expressions.map((expression) => `<li class="text-sm text-gray-700">• ${expression}</li>`).join('')}
          </ul>
        `;
      } else {
        const fallback = getCurrentWeekFallback();
        fillWeeklyForm({ ...fallback, expressions: [] });
        container.innerHTML = '<p class="text-sm text-gray-500">Aucune semaine chargee</p>';
      }

      renderWeeklyArchives();
    } catch (error) {
      console.error('Erreur lors du chargement des expressions:', error);
    }
  }

  async function reloadWeeklyExpressions() {
    await loadWeeklyExpressions();
  }

