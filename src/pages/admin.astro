  window.definirDefi = async function() {
    const weekId = document.getElementById('weekIdInput').value.trim();
    const startDate = document.getElementById('weekStartInput').value;
    const endDate = document.getElementById('weekEndInput').value;
    const expressions = parseExpressionsInput(document.getElementById('defiInput').value);

    const fallback = getCurrentWeekFallback();

    try {
      validateWeeklyForm({
        weekId: weekId || fallback.weekId,
        startDate: startDate || fallback.startDate,
        endDate: endDate || fallback.endDate,
        expressions
      });

      await window.setWeeklyExpressionsForWeek({
        weekId: weekId || fallback.weekId,
        startDate: startDate || fallback.startDate,
        endDate: endDate || fallback.endDate,
        expressions
      });
      await reloadWeeklyExpressions();
    } catch (error) {
      alert('Erreur lors de la sauvegarde des expressions: ' + error.message);
    }
  }

  window.reparerMigrationLegacy = async function() {
    const status = document.getElementById('legacyRepairStatus');
    if (status) status.textContent = 'Reparation en cours...';

    try {
      if (typeof window.repairLegacyMigrationWeeks !== 'function') {
        throw new Error('Fonction de reparation indisponible');
      }

      const result = await window.repairLegacyMigrationWeeks();
      await reloadWeeklyExpressions();

      if (!status) return;
      if (result?.repaired) {
        status.textContent = `Migration legacy reparee (semaine: ${result.expectedWeekId}, mode: ${result.selectionMode}).`;
      } else {
        status.textContent = `Aucune correction appliquee (${result?.reason || 'inconnu'}).`;
      }
    } catch (error) {
      if (status) status.textContent = `Echec de reparation: ${error.message}`;
    }
  }

