          <label class="block text-xs font-medium text-gray-700 mb-1">Remarque de l'enseignant (optionnel)</label>
          <textarea id="editRemarque-${id}" rows="3"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">${texte.remarqueEnseignant || ''}</textarea>
        </div>
        
        <div class="flex gap-2">
          <button onclick="saveTexte('${id}')" 
                  class="bg-indigo-600 text-white px-3 py-1.5 rounded-md text-xs hover:bg-indigo-700 transition-colors">
            Sauvegarder
          </button>
          <button onclick="cancelEdit('${id}')" 
                  class="bg-gray-200 text-gray-700 px-3 py-1.5 rounded-md text-xs hover:bg-gray-300 transition-colors">
            Annuler
          </button>
        </div>
      </div>
    `;

    // Insérer le formulaire après la carte du texte
    const texteCard = document.querySelector(`[data-texte-id="${id}"]`);
    if (texteCard) {
      texteCard.insertAdjacentHTML('afterend', editForm);
      texteCard.style.display = 'none';
    }
  }

  window.saveTexte = async function(id) {
    const titre = document.getElementById(`editTitle-${id}`).value.trim();
    const contenu = document.getElementById(`editContent-${id}`).value.trim();
    const remarqueEnseignant = document.getElementById(`editRemarque-${id}`).value.trim();
    
    if (!titre || !contenu) {
      alert('Le titre et le contenu ne peuvent pas être vides');
      return;
    }

    try {
      await window.updateTexte(id, { titre, contenu, remarqueEnseignant });
      window.loadTextes();
    } catch (error) {
      alert('Erreur lors de la sauvegarde: ' + error.message);
    }
  }

  window.cancelEdit = function(id) {
    const editForm = document.getElementById(`editForm-${id}`);
    const texteCard = document.querySelector(`[data-texte-id="${id}"]`);
    
    if (editForm) editForm.remove();
    if (texteCard) texteCard.style.display = '';
  }

  window.editGroupe = function(id) {
    const groupe = groupes.find(g => g.id === id);
    if (!groupe) return;

    // Créer le formulaire d'édition
    const editForm = `
      <div id="editGroupeForm-${id}" class="bg-white border border-indigo-200 rounded-lg p-4 mb-4">
        <h4 class="text-sm font-medium text-gray-900 mb-3">Modifier le groupe</h4>
        
        <div class="mb-3">
          <label class="block text-xs font-medium text-gray-700 mb-1">Nom du groupe</label>
          <input type="text" id="editGroupeName-${id}" value="${groupe.nom}" 
                 class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
        </div>
        
        <div class="flex gap-2">
          <button onclick="saveGroupe('${id}')" 
                  class="bg-indigo-600 text-white px-3 py-1.5 rounded-md text-xs hover:bg-indigo-700 transition-colors">
            Sauvegarder
          </button>
          <button onclick="cancelGroupeEdit('${id}')" 
                  class="bg-gray-200 text-gray-700 px-3 py-1.5 rounded-md text-xs hover:bg-gray-300 transition-colors">
            Annuler
          </button>
        </div>
      </div>
    `;

    // Insérer le formulaire après la carte du groupe
    const groupeCard = document.querySelector(`[data-groupe-id="${id}"]`);
    if (groupeCard) {
      groupeCard.insertAdjacentHTML('afterend', editForm);
      groupeCard.style.display = 'none';
    }
  }

  window.saveGroupe = async function(id) {
    const nom = document.getElementById(`editGroupeName-${id}`).value.trim();
    
    if (!nom) {
      alert('Le nom du groupe ne peut pas être vide');
      return;
    }

    try {
      // Récupérer l'ancien nom du groupe
      const groupe = groupes.find(g => g.id === id);
      const ancienNom = groupe.nom;
      
      // Mettre à jour le groupe
      await window.updateGroupe(id, { nom });
      
      // Si le nom a changé, mettre à jour tous les textes de ce groupe
      if (ancienNom !== nom) {
        const textesDuGroupe = textes.filter(texte => texte.groupeNom === ancienNom);
        
        // Mettre à jour tous les textes en parallèle
        await Promise.all(
          textesDuGroupe.map(texte => 
            window.updateTexte(texte.id, { groupeNom: nom })
          )
        );
      }
      
      window.loadGroupes();
      window.loadTextes();
    } catch (error) {
      alert('Erreur lors de la sauvegarde: ' + error.message);
    }
  }

  window.cancelGroupeEdit = function(id) {
    const editForm = document.getElementById(`editGroupeForm-${id}`);
    const groupeCard = document.querySelector(`[data-groupe-id="${id}"]`);
    
    if (editForm) editForm.remove();
    if (groupeCard) groupeCard.style.display = '';
  }
</script>

