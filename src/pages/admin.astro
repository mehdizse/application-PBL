  async function loadWinningTeam() {
    try {
      winningTeamData = await window.getWinningTeam();
      if (!winningTeamData) {
        winningTeamData = {
          teams: {
            a: { groupeId: '', texteId: '', members: [{ prenom: '', photoUrl: '', storagePath: '' }, { prenom: '', photoUrl: '', storagePath: '' }, { prenom: '', photoUrl: '', storagePath: '' }] },
            b: { groupeId: '', texteId: '', members: [{ prenom: '', photoUrl: '', storagePath: '' }, { prenom: '', photoUrl: '', storagePath: '' }, { prenom: '', photoUrl: '', storagePath: '' }] }
          },
          winner: ''
        };
      }

      winningTeamData.teams = winningTeamData.teams || {};
      winningTeamData.teams.a = winningTeamData.teams.a || { groupeId: '', texteId: '', members: [] };
      winningTeamData.teams.b = winningTeamData.teams.b || { groupeId: '', texteId: '', members: [] };

      const ensureMembers = (teamKey) => {
        const members = Array.isArray(winningTeamData.teams[teamKey].members) ? winningTeamData.teams[teamKey].members : [];
        while (members.length < 3) members.push({ prenom: '', photoUrl: '', storagePath: '' });
        winningTeamData.teams[teamKey].members = members.slice(0, 3).map((m) => ({
          prenom: String(m?.prenom || ''),
          photoUrl: String(m?.photoUrl || ''),
          storagePath: String(m?.storagePath || '')
        }));
      };

      ensureMembers('a');
      ensureMembers('b');
      winningTeamData.winner = String(winningTeamData.winner || '');

      setupWinningTeamListenersOnce();
      renderWinningTeamForm();
      setWinningTeamStatus('Prêt');
    } catch (error) {
      console.error('Erreur loadWinningTeam:', error);
      setWinningTeamStatus('Erreur de chargement');
    }
  }

  let winningTeamListenersReady = false;

  function setupWinningTeamListenersOnce() {
    if (winningTeamListenersReady) return;
    winningTeamListenersReady = true;

    const groupASelect = document.getElementById('winningGroupASelect');
    const groupBSelect = document.getElementById('winningGroupBSelect');
    const texteASelect = document.getElementById('winningTexteASelect');
    const texteBSelect = document.getElementById('winningTexteBSelect');
    const saveBtn = document.getElementById('winningTeamSaveBtn');
    const winnerBtnA = document.getElementById('winnerBtnA');
    const winnerBtnB = document.getElementById('winnerBtnB');

    groupASelect.addEventListener('change', () => {
      winningTeamData.teams.a.groupeId = groupASelect.value;
      winningTeamData.teams.a.texteId = '';
      renderWinningTeamForm();
    });

    groupBSelect.addEventListener('change', () => {
      winningTeamData.teams.b.groupeId = groupBSelect.value;
      winningTeamData.teams.b.texteId = '';
      renderWinningTeamForm();
    });

    texteASelect.addEventListener('change', () => {
      winningTeamData.teams.a.texteId = texteASelect.value;
    });

    texteBSelect.addEventListener('change', () => {
      winningTeamData.teams.b.texteId = texteBSelect.value;
    });

    winnerBtnA.addEventListener('click', async () => {
      winningTeamData.winner = 'a';
      renderWinningTeamForm();
      await saveWinningTeam();
    });

    winnerBtnB.addEventListener('click', async () => {
      winningTeamData.winner = 'b';
      renderWinningTeamForm();
      await saveWinningTeam();
    });

    saveBtn.addEventListener('click', saveWinningTeam);

    const attachMemberListeners = (teamKey) => {
      for (let i = 0; i < 3; i += 1) {
        const prenomInput = document.getElementById(`winningPrenom${teamKey.toUpperCase()}${i}`);
        const photoInput = document.getElementById(`winningPhoto${teamKey.toUpperCase()}${i}`);
        prenomInput.addEventListener('input', () => {
          winningTeamData.teams[teamKey].members[i].prenom = prenomInput.value;
        });

        photoInput.addEventListener('change', async () => {
          try {
            const file = photoInput.files?.[0];
            if (!file) return;

            const groupId = winningTeamData.teams[teamKey].groupeId;
            if (!groupId) {
              alert('Sélectionnez d\'abord un groupe');
              photoInput.value = '';
              return;
            }

            setWinningTeamStatus('Upload en cours...');
            const existingStoragePath = String(winningTeamData.teams[teamKey].members[i].storagePath || '');
            const { storagePath, downloadUrl } = await window.uploadWinningTeamPhoto({ groupId, slot: i, file });
            winningTeamData.teams[teamKey].members[i].storagePath = storagePath;
            winningTeamData.teams[teamKey].members[i].photoUrl = downloadUrl;
            renderWinningTeamForm();

            if (existingStoragePath && existingStoragePath !== storagePath) {
              try {
                await window.deleteWinningTeamPhoto({ storagePath: existingStoragePath });
              } catch (error) {
                console.error('Erreur suppression ancienne photo:', error);
              }
            }

            await saveWinningTeam();
          } catch (error) {
            console.error('Erreur upload photo:', error);
            const details = error.code ? `Code: ${error.code}` : '';
            alert(`Erreur upload: ${error.message}\n${details}`);
            setWinningTeamStatus('Erreur upload');
            photoInput.value = '';
          }
        });
      }
    };

    attachMemberListeners('a');
    attachMemberListeners('b');
  }

  function renderWinningTeamForm() {
    const groupASelect = document.getElementById('winningGroupASelect');
    const groupBSelect = document.getElementById('winningGroupBSelect');
    const texteASelect = document.getElementById('winningTexteASelect');
    const texteBSelect = document.getElementById('winningTexteBSelect');
    const winnerBtnA = document.getElementById('winnerBtnA');
    const winnerBtnB = document.getElementById('winnerBtnB');

    const selectedA = String(winningTeamData?.teams?.a?.groupeId || '');
    const selectedB = String(winningTeamData?.teams?.b?.groupeId || '');

    const buildGroupeOptions = ({ selectedValue, disabledValue }) => {
