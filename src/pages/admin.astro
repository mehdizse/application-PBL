---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Ajout d'espace pour le header fixe -->
  <div class="pt-12 min-h-screen bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 py-6">
      <!-- Header Admin -->
      <div class="bg-white border border-gray-200 rounded-lg p-3 mb-4">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-lg font-medium text-gray-900">
              Espace Enseignant
            </h1>
            <p class="text-sm text-gray-500">Gérez les productions de vos élèves</p>
          </div>
          <div id="userInfo" class="text-right">
            <p class="text-xs text-gray-400">Non connecté</p>
          </div>
        </div>
      </div>

      <!-- Section Connexion -->
      <div id="loginSection" class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
        <h2 class="text-base font-medium text-gray-900 mb-4">Connexion Enseignant</h2>
        <form id="loginForm" class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" id="email" required 
                   class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
            <input type="password" id="password" required 
                   class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
          </div>
          <button type="submit" 
                  class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition-colors">
            Se connecter
          </button>
        </form>
        <div id="loginError" class="mt-3 p-2 bg-red-50 border border-red-200 text-red-600 text-sm rounded-md hidden">
          Erreur de connexion
        </div>
      </div>

      <!-- Dashboard Admin -->
      <div id="dashboardSection" class="hidden">
        <!-- Défi de la semaine -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
          <h2 class="text-base font-medium text-gray-900 mb-3">
            Défi de la semaine
          </h2>
          <div class="space-y-2">
            <textarea id="defiInput" placeholder="Ex:&#10;- Utiliser 3 connecteurs logiques&#10;- Écrire au moins 8 lignes&#10;- Ajouter une conclusion" 
                     rows="3" 
                     class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 resize-none"></textarea>
            <button onclick="definirDefi()" 
                    class="bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700 transition-colors">
              Définir le défi
            </button>
          </div>
          <div id="defiActuel" class="mt-2 p-2 bg-gray-50 border border-gray-200 rounded-md">
            <p class="text-sm text-gray-600">Aucun défi défini</p>
          </div>
        </div>

        <!-- Actions rapides -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-2 mb-4">
          <button onclick="showAddGroupeModal()" 
                  class="bg-white border border-gray-300 text-gray-700 p-3 rounded-md hover:bg-gray-50 transition-colors text-center">
            <div class="text-base mb-1">+</div>
            <div class="text-sm font-medium">Ajouter un groupe</div>
          </button>
          <button onclick="showAddTexteModal()" 
                  class="bg-indigo-600 text-white p-3 rounded-md hover:bg-indigo-700 transition-colors text-center">
            <div class="text-base mb-1">📝</div>
            <div class="text-sm font-medium">Ajouter un texte</div>
          </button>
          <button onclick="showBadgesModal()" 
                  class="bg-white border border-gray-300 text-gray-700 p-3 rounded-md hover:bg-gray-50 transition-colors text-center">
            <div class="text-base mb-1">🏆</div>
            <div class="text-sm font-medium">Gérer les badges</div>
          </button>
        </div>

        <!-- Liste des groupes -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
          <h2 class="text-base font-medium text-gray-900 mb-3">
            Groupes d'élèves
          </h2>
          <div id="groupesList" class="space-y-2">
            <p class="text-gray-400 text-sm">Chargement...</p>
          </div>
        </div>

        <!-- Liste des textes -->
        <div class="bg-white border border-gray-200 rounded-lg p-4">
          <h2 class="text-base font-medium text-gray-900 mb-3">
            Textes des élèves
          </h2>
          <div id="textesList" class="space-y-3">
            <p class="text-gray-400 text-sm">Chargement...</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modals -->
  <!-- Modal Ajout Groupe -->
  <div id="addGroupeModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center z-50">
    <div class="bg-white border border-gray-200 rounded-lg p-6 w-96 shadow-lg">
      <h3 class="text-base font-medium text-gray-900 mb-4">Ajouter un groupe</h3>
      <input type="text" id="groupeNomInput" placeholder="Nom du groupe (ex: Groupe A)" 
             class="w-full px-3 py-2 border border-gray-300 rounded-md mb-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
      <div class="flex gap-2">
        <button onclick="ajouterGroupe()" class="flex-1 bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition-colors">
          Ajouter
        </button>
        <button onclick="closeModal('addGroupeModal')" class="flex-1 bg-white border border-gray-300 text-gray-700 py-2 rounded-md hover:bg-gray-50 transition-colors">
          Annuler
        </button>
      </div>
    </div>
  </div>

  <!-- Modal Ajout Texte -->
  <div id="addTexteModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center z-50">
    <div class="bg-white border border-gray-200 rounded-lg p-6 w-full max-w-2xl max-h-[80vh] overflow-y-auto shadow-lg">
      <h3 class="text-base font-medium text-gray-900 mb-4">Ajouter un texte</h3>
      <form id="texteForm" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Groupe</label>
          <select id="texteGroupeSelect" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
            <option value="">Sélectionner un groupe</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Titre</label>
          <input type="text" id="texteTitreInput" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
          <select id="texteTypeSelect" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
            <option value="Récit d'aventure">Récit d'aventure</option>
            <option value="Texte descriptif">Texte descriptif</option>
            <option value="Nouvelle fantastique">Nouvelle fantastique</option>
            <option value="Récit de voyage">Récit de voyage</option>
            <option value="Poème">Poème</option>
            <option value="Lettre">Lettre</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Contenu</label>
          <textarea id="texteContenuInput" rows="10" 
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"></textarea>
        </div>
        <div class="flex gap-2">
          <button type="submit" class="flex-1 bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition-colors">
            Ajouter le texte
          </button>
          <button type="button" onclick="closeModal('addTexteModal')" 
                  class="flex-1 bg-white border border-gray-300 text-gray-700 py-2 rounded-md hover:bg-gray-50 transition-colors">
            Annuler
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Badges -->
  <div id="badgesModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center z-50">
    <div class="bg-white border border-gray-200 rounded-lg p-6 w-full max-w-2xl shadow-lg max-h-[80vh] overflow-y-auto">
      <h3 class="text-base font-medium text-gray-900 mb-4">Gérer les badges</h3>
      <div id="badgesList" class="space-y-3">
        <!-- Badges will be loaded here -->
      </div>
      <div class="mt-4 flex justify-end">
        <button onclick="closeModal('badgesModal')" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-md hover:bg-gray-300 transition-colors">
          Fermer
        </button>
      </div>
    </div>
  </div>

  <!-- Modal Confirmation -->
  <div id="confirmModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center z-50">
    <div class="bg-white border border-gray-200 rounded-lg p-6 w-96 shadow-lg">
      <div class="flex items-center mb-4">
        <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mr-3">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-medium text-gray-900">Confirmer la suppression</h3>
          <p class="text-sm text-gray-500">Cette action est irréversible</p>
        </div>
      </div>
      
      <div id="confirmMessage" class="text-sm text-gray-700 mb-6 bg-gray-50 p-3 rounded-md">
        <!-- Message will be inserted here -->
      </div>
      
      <div class="flex gap-3">
        <button onclick="confirmAction()" class="flex-1 bg-red-600 text-white py-2 rounded-md hover:bg-red-700 transition-colors font-medium">
          Supprimer
        </button>
        <button onclick="closeConfirmModal()" class="flex-1 bg-gray-200 text-gray-700 py-2 rounded-md hover:bg-gray-300 transition-colors font-medium">
          Annuler
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Les fonctions Firebase sont chargées globalement via les balises script dans BaseLayout
  let currentUser = null;
  let groupes = [];
  let textes = [];

  // Initialisation
  document.addEventListener('DOMContentLoaded', async () => {
    // Attendre que Firebase soit initialisé
    function waitForFirebase() {
      if (typeof window.onAuthStateChanged === 'undefined') {
        setTimeout(waitForFirebase, 100);
        return;
      }
      
      // Vérifier l'état d'authentification
      window.onAuthStateChanged(window.auth, (user) => {
        currentUser = user;
        if (user) {
          showDashboard();
          loadDashboard();
        } else {
          showLogin();
        }
      });

      // Gérer le formulaire de connexion
      document.getElementById('loginForm').addEventListener('submit', handleLogin);
      document.getElementById('texteForm').addEventListener('submit', handleAddTexte);
    }
    
    waitForFirebase();
  });

  function showLogin() {
    document.getElementById('loginSection').classList.remove('hidden');
    document.getElementById('dashboardSection').classList.add('hidden');
    document.getElementById('userInfo').innerHTML = '<p class="text-sm text-gray-600">Non connecté</p>';
  }

  function showDashboard() {
    document.getElementById('loginSection').classList.add('hidden');
    document.getElementById('dashboardSection').classList.remove('hidden');
    document.getElementById('userInfo').innerHTML = `
      <p class="text-xs text-gray-500">Connecté en tant que</p>
      <p class="text-sm font-medium text-gray-900">${currentUser.email}</p>
      <button onclick="logout()" class="mt-1 text-xs text-gray-500 hover:text-gray-700 underline">Déconnexion</button>
    `;
  }

  async function handleLogin(e) {
    e.preventDefault();
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const errorDiv = document.getElementById('loginError');

    try {
      await window.signInWithEmailAndPassword(window.auth, email, password);
      errorDiv.classList.add('hidden');
    } catch (error) {
      // Messages conviviales selon le type d'erreur
      let friendlyMessage = 'Erreur de connexion';
      
      if (error.code === 'auth/invalid-credential' || error.code === 'auth/wrong-password') {
        friendlyMessage = 'Email ou mot de passe incorrect';
      } else if (error.code === 'auth/user-not-found') {
        friendlyMessage = 'Aucun compte trouvé avec cet email';
      } else if (error.code === 'auth/too-many-requests') {
        friendlyMessage = 'Trop de tentatives de connexion. Veuillez réessayer plus tard';
      } else if (error.code === 'auth/network-request-failed') {
        friendlyMessage = 'Problème de connexion. Vérifiez votre internet';
      } else {
        friendlyMessage = 'Erreur de connexion. Veuillez réessayer';
      }
      
      errorDiv.textContent = friendlyMessage;
      errorDiv.classList.remove('hidden');
    }
  }

  async function logout() {
    await window.signOut();
  }

  // Rendre logout disponible globalement
  window.logout = logout;

  async function loadDashboard() {
    await Promise.all([
      window.loadGroupes(),
      window.loadTextes(),
      loadDefi()
    ]);
  }

  window.loadGroupes = async function() {
    try {
      groupes = await window.getGroupes();
      const container = document.getElementById('groupesList');
      const select = document.getElementById('texteGroupeSelect');
      
      if (groupes.length === 0) {
        container.innerHTML = '<p class="text-gray-500">Aucun groupe pour le moment</p>';
        select.innerHTML = '<option value="">Aucun groupe disponible</option>';
        return;
      }

      container.innerHTML = groupes.map(groupe => `
        <div class="flex items-center justify-between p-2 border border-gray-200 rounded-md" data-groupe-id="${groupe.id}">
          <div>
            <span class="text-sm font-medium text-gray-900">${groupe.nom}</span>
            <span class="ml-2 text-xs ${groupe.visible ? 'text-green-600' : 'text-red-600'}">
              ${groupe.visible ? 'Visible' : 'Masqué'}
            </span>
          </div>
          <div class="flex gap-1">
            <button onclick="toggleGroupeVisibility('${groupe.id}', ${!groupe.visible})" 
                    class="px-2 py-1 text-xs ${groupe.visible ? 'bg-gray-100 hover:bg-gray-200 text-gray-700' : 'bg-indigo-600 hover:bg-indigo-700 text-white'} rounded transition-colors">
              ${groupe.visible ? 'Masquer' : 'Afficher'}
            </button>
            <button onclick="editGroupe('${groupe.id}')" 
                    class="px-2 py-1 text-xs bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 rounded transition-colors">
              Modifier
            </button>
            <button onclick="deleteGroupeById('${groupe.id}')" 
                    class="px-2 py-1 text-xs bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 rounded transition-colors">
              Supprimer
            </button>
          </div>
        </div>
      `).join('');

      select.innerHTML = '<option value="">Sélectionner un groupe</option>' + 
        groupes.map(g => `<option value="${g.id}">${g.nom}</option>`).join('');
    } catch (error) {
      console.error('Erreur lors du chargement des groupes:', error);
    }
  }

  window.loadTextes = async function() {
    try {
      textes = await window.getTextes();
      const container = document.getElementById('textesList');
      
      if (textes.length === 0) {
        container.innerHTML = '<p class="text-gray-500">Aucun texte pour le moment</p>';
        return;
      }

      container.innerHTML = textes.map(texte => `
        <div class="border border-gray-200 rounded-md p-3" data-texte-id="${texte.id}">
          <div class="flex items-start justify-between mb-2">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-block bg-gray-100 text-gray-700 px-2 py-0.5 rounded text-xs font-medium">
                  ${texte.groupeNom}
                </span>
                <span class="text-sm font-medium text-gray-900">${texte.titre}</span>
              </div>
              <span class="text-xs text-gray-500">${texte.type}</span>
            </div>
            <div class="flex items-center gap-1">
              ${texte.badges && texte.badges.length > 0 ? `
                <div class="flex gap-1 mr-2">
                  ${texte.badges.map(badge => `<span class="text-xs">${badge}</span>`).join('')}
                </div>
              ` : ''}
              <span class="text-xs ${texte.visible ? 'text-green-600' : 'text-red-600'}">
                ${texte.visible ? 'Visible' : 'Masqué'}
              </span>
            </div>
          </div>
          
          <div class="text-xs text-gray-400 mb-2">
            Créé le ${new Date(texte.createdAt?.toDate?.() || texte.createdAt).toLocaleDateString('fr-FR')}
          </div>
          
          <div class="flex gap-1">
            <button onclick="toggleTexteVisibility('${texte.id}', ${!texte.visible})" 
                    class="px-2 py-1 text-xs ${texte.visible ? 'bg-gray-100 hover:bg-gray-200 text-gray-700' : 'bg-indigo-600 hover:bg-indigo-700 text-white'} rounded transition-colors">
              ${texte.visible ? 'Masquer' : 'Afficher'}
            </button>
            <button onclick="editTexte('${texte.id}')" 
                    class="px-2 py-1 text-xs bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 rounded transition-colors">
              Modifier
            </button>
            <button onclick="deleteTexteById('${texte.id}')" 
                    class="px-2 py-1 text-xs bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 rounded transition-colors">
              Supprimer
            </button>
          </div>
        </div>
      `).join('');
    } catch (error) {
      console.error('Erreur lors du chargement des textes:', error);
    }
  }

  async function loadDefi() {
    try {
      const defi = await window.getDefiActuel();
      const container = document.getElementById('defiActuel');
      const input = document.getElementById('defiInput');
      
      if (defi) {
        container.innerHTML = `
          <p class="text-sm font-medium text-gray-900">Défi actuel</p>
          <div class="text-sm text-gray-700 whitespace-pre-line">${defi.texte}</div>
        `;
        input.value = defi.texte;
      } else {
        container.innerHTML = '<p class="text-sm text-gray-500">Aucun défi défini</p>';
      }
    } catch (error) {
      console.error('Erreur lors du chargement du défi:', error);
    }
  }

  // Fonctions pour les modals
  window.showAddGroupeModal = function() {
    document.getElementById('addGroupeModal').classList.remove('hidden');
  }

  window.showAddTexteModal = function() {
    document.getElementById('addTexteModal').classList.remove('hidden');
  }

  window.showBadgesModal = function() {
    document.getElementById('badgesModal').classList.remove('hidden');
    window.loadBadges();
  }

  window.closeModal = function(modalId) {
    document.getElementById(modalId).classList.add('hidden');
  }

  // Fonctions pour le modal de confirmation
  let pendingAction = null;

  window.showConfirmModal = function(message, action) {
    document.getElementById('confirmMessage').innerHTML = message;
    document.getElementById('confirmModal').classList.remove('hidden');
    pendingAction = action;
  }

  window.closeConfirmModal = function() {
    document.getElementById('confirmModal').classList.add('hidden');
    pendingAction = null;
  }

  window.confirmAction = function() {
    if (pendingAction) {
      pendingAction();
      closeConfirmModal();
    }
  }

  // Actions
  window.ajouterGroupe = async function() {
    const nom = document.getElementById('groupeNomInput').value.trim();
    if (!nom) return;

    try {
      await window.addGroupe(nom);
      document.getElementById('groupeNomInput').value = '';
      window.closeModal('addGroupeModal');
      window.loadGroupes();
    } catch (error) {
      alert('Erreur lors de l\'ajout du groupe: ' + error.message);
    }
  }

  window.handleAddTexte = async function(e) {
    e.preventDefault();
    
    const groupeId = document.getElementById('texteGroupeSelect').value;
    const titre = document.getElementById('texteTitreInput').value.trim();
    const type = document.getElementById('texteTypeSelect').value;
    const contenu = document.getElementById('texteContenuInput').value.trim();
    
    if (!groupeId || !titre || !contenu) return;

    const groupe = groupes.find(g => g.id === groupeId);
    
    try {
      await window.addTexte({
        groupeId,
        groupeNom: groupe.nom,
        titre,
        type,
        contenu,
        badges: []
      });
      
      document.getElementById('texteForm').reset();
      window.closeModal('addTexteModal');
      window.loadTextes();
    } catch (error) {
      alert('Erreur lors de l\'ajout du texte: ' + error.message);
    }
  }

  window.toggleGroupeVisibility = async function(id, visible) {
    try {
      await window.updateGroupe(id, { visible });
      window.loadGroupes();
    } catch (error) {
      alert('Erreur lors de la mise à jour du groupe: ' + error.message);
    }
  }

  window.toggleTexteVisibility = async function(id, visible) {
    try {
      await window.updateTexte(id, { visible });
      window.loadTextes();
    } catch (error) {
      alert('Erreur lors de la mise à jour du texte: ' + error.message);
    }
  }

  window.deleteGroupeById = function(id) {
    const groupe = groupes.find(g => g.id === id);
    if (!groupe) return;
    
    const message = `
      <div class="space-y-2">
        <p class="font-medium">Êtes-vous sûr de vouloir supprimer ce groupe ?</p>
        <div class="bg-white p-2 rounded border border-gray-200">
          <p class="font-medium text-gray-900">${groupe.nom}</p>
          <p class="text-xs text-gray-500">Statut: ${groupe.visible ? 'Visible' : 'Masqué'}</p>
        </div>
        <p class="text-red-600 text-xs">⚠️ Cette action est irréversible</p>
      </div>
    `;
    
    showConfirmModal(message, async () => {
      try {
        await window.deleteGroupe(id);
        window.loadGroupes();
        window.loadTextes();
      } catch (error) {
        alert('Erreur lors de la suppression du groupe: ' + error.message);
      }
    });
  }

  window.deleteTexteById = function(id) {
    const texte = textes.find(t => t.id === id);
    if (!texte) return;
    
    const message = `
      <div class="space-y-2">
        <p class="font-medium">Êtes-vous sûr de vouloir supprimer ce texte ?</p>
        <div class="bg-white p-2 rounded border border-gray-200">
          <p class="font-medium text-gray-900">${texte.titre}</p>
          <p class="text-xs text-gray-500">Groupe: ${texte.groupeNom}</p>
          <p class="text-xs text-gray-500">Type: ${texte.type}</p>
        </div>
        <p class="text-red-600 text-xs">⚠️ Cette action est irréversible</p>
      </div>
    `;
    
    showConfirmModal(message, async () => {
      try {
        await window.deleteTexte(id);
        window.loadTextes();
      } catch (error) {
        alert('Erreur lors de la suppression du texte: ' + error.message);
      }
    });
  }

  window.definirDefi = async function() {
    const defiTexte = document.getElementById('defiInput').value.trim();
    if (!defiTexte) return;

    try {
      await window.setDefi(defiTexte);
      loadDefi();
    } catch (error) {
      alert('Erreur lors de la définition du défi: ' + error.message);
    }
  }

  window.loadBadges = function() {
    const badges = ['⭐', '🏆', '🔗', '✍️', '🤝'];
    const container = document.getElementById('badgesList');
    
    container.innerHTML = textes.map(texte => `
      <div class="border border-gray-200 rounded-md p-3">
        <div class="text-sm font-medium text-gray-900 mb-2">${texte.titre} (${texte.groupeNom})</div>
        <div class="flex gap-1 flex-wrap">
          ${badges.map(badge => `
            <button onclick="toggleBadge('${texte.id}', '${badge}')" 
                    class="text-sm p-1.5 rounded ${texte.badges?.includes(badge) ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-500'} hover:bg-gray-200 transition-colors">
              ${badge}
            </button>
          `).join('')}
        </div>
      </div>
    `).join('');
  }

  window.toggleBadge = async function(texteId, badge) {
    const texte = textes.find(t => t.id === texteId);
    const badges = texte.badges || [];
    
    if (badges.includes(badge)) {
      badges.splice(badges.indexOf(badge), 1);
    } else {
      badges.push(badge);
    }
    
    try {
      await window.updateTexte(texteId, { badges });
      window.loadTextes();
      window.loadBadges();
    } catch (error) {
      alert('Erreur lors de la mise à jour des badges: ' + error.message);
    }
  }

  window.editTexte = function(id) {
    const texte = textes.find(t => t.id === id);
    if (!texte) return;

    // Créer le formulaire d'édition
    const editForm = `
      <div id="editForm-${id}" class="bg-white border border-indigo-200 rounded-lg p-4 mb-4">
        <h4 class="text-sm font-medium text-gray-900 mb-3">Modifier le texte</h4>
        
        <div class="mb-3">
          <label class="block text-xs font-medium text-gray-700 mb-1">Titre</label>
          <input type="text" id="editTitle-${id}" value="${texte.titre}" 
                 class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
        </div>
        
        <div class="mb-3">
          <label class="block text-xs font-medium text-gray-700 mb-1">Contenu</label>
          <textarea id="editContent-${id}" rows="8" 
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">${texte.contenu}</textarea>
        </div>
        
        <div class="flex gap-2">
          <button onclick="saveTexte('${id}')" 
                  class="bg-indigo-600 text-white px-3 py-1.5 rounded-md text-xs hover:bg-indigo-700 transition-colors">
            Sauvegarder
          </button>
          <button onclick="cancelEdit('${id}')" 
                  class="bg-gray-200 text-gray-700 px-3 py-1.5 rounded-md text-xs hover:bg-gray-300 transition-colors">
            Annuler
          </button>
        </div>
      </div>
    `;

    // Insérer le formulaire après la carte du texte
    const texteCard = document.querySelector(`[data-texte-id="${id}"]`);
    if (texteCard) {
      texteCard.insertAdjacentHTML('afterend', editForm);
      texteCard.style.display = 'none';
    }
  }

  window.saveTexte = async function(id) {
    const titre = document.getElementById(`editTitle-${id}`).value.trim();
    const contenu = document.getElementById(`editContent-${id}`).value.trim();
    
    if (!titre || !contenu) {
      alert('Le titre et le contenu ne peuvent pas être vides');
      return;
    }

    try {
      await window.updateTexte(id, { titre, contenu });
      window.loadTextes();
    } catch (error) {
      alert('Erreur lors de la sauvegarde: ' + error.message);
    }
  }

  window.cancelEdit = function(id) {
    const editForm = document.getElementById(`editForm-${id}`);
    const texteCard = document.querySelector(`[data-texte-id="${id}"]`);
    
    if (editForm) editForm.remove();
    if (texteCard) texteCard.style.display = '';
  }

  window.editGroupe = function(id) {
    const groupe = groupes.find(g => g.id === id);
    if (!groupe) return;

    // Créer le formulaire d'édition
    const editForm = `
      <div id="editGroupeForm-${id}" class="bg-white border border-indigo-200 rounded-lg p-4 mb-4">
        <h4 class="text-sm font-medium text-gray-900 mb-3">Modifier le groupe</h4>
        
        <div class="mb-3">
          <label class="block text-xs font-medium text-gray-700 mb-1">Nom du groupe</label>
          <input type="text" id="editGroupeName-${id}" value="${groupe.nom}" 
                 class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
        </div>
        
        <div class="flex gap-2">
          <button onclick="saveGroupe('${id}')" 
                  class="bg-indigo-600 text-white px-3 py-1.5 rounded-md text-xs hover:bg-indigo-700 transition-colors">
            Sauvegarder
          </button>
          <button onclick="cancelGroupeEdit('${id}')" 
                  class="bg-gray-200 text-gray-700 px-3 py-1.5 rounded-md text-xs hover:bg-gray-300 transition-colors">
            Annuler
          </button>
        </div>
      </div>
    `;

    // Insérer le formulaire après la carte du groupe
    const groupeCard = document.querySelector(`[data-groupe-id="${id}"]`);
    if (groupeCard) {
      groupeCard.insertAdjacentHTML('afterend', editForm);
      groupeCard.style.display = 'none';
    }
  }

  window.saveGroupe = async function(id) {
    const nom = document.getElementById(`editGroupeName-${id}`).value.trim();
    
    if (!nom) {
      alert('Le nom du groupe ne peut pas être vide');
      return;
    }

    try {
      // Récupérer l'ancien nom du groupe
      const groupe = groupes.find(g => g.id === id);
      const ancienNom = groupe.nom;
      
      // Mettre à jour le groupe
      await window.updateGroupe(id, { nom });
      
      // Si le nom a changé, mettre à jour tous les textes de ce groupe
      if (ancienNom !== nom) {
        const textesDuGroupe = textes.filter(texte => texte.groupeNom === ancienNom);
        
        // Mettre à jour tous les textes en parallèle
        await Promise.all(
          textesDuGroupe.map(texte => 
            window.updateTexte(texte.id, { groupeNom: nom })
          )
        );
      }
      
      window.loadGroupes();
      window.loadTextes();
    } catch (error) {
      alert('Erreur lors de la sauvegarde: ' + error.message);
    }
  }

  window.cancelGroupeEdit = function(id) {
    const editForm = document.getElementById(`editGroupeForm-${id}`);
    const groupeCard = document.querySelector(`[data-groupe-id="${id}"]`);
    
    if (editForm) editForm.remove();
    if (groupeCard) groupeCard.style.display = '';
  }
</script>
