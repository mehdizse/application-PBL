---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Ajout d'espace pour le header fixe -->
  <div class="pt-12 min-h-screen bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 py-6">
      <!-- Titre principal épuré -->
      <div class="text-center mb-6">
        <h1 class="text-2xl md:text-3xl font-medium text-gray-900 mb-2">
          Le Mur des Textes
        </h1>
        <p class="text-sm text-gray-600">
          Les productions d'expression écrite
        </p>
      </div>

    <!-- Défi de la semaine -->
    <div id="defiSection" class="bg-white border border-gray-200 rounded-lg p-4 mb-4 hidden">
      <div class="text-center">
        <h2 class="text-base font-medium text-gray-900 mb-2">Défi de la semaine</h2>
        <p id="defiTexte" class="text-sm text-gray-700 leading-relaxed"></p>
      </div>
    </div>

    <!-- Liste des productions par groupe -->
    <div id="textesContainer" class="space-y-3">
      <div class="text-center py-8">
        <p class="text-sm text-gray-500">Chargement des textes...</p>
      </div>
    </div>

    <!-- Message motivant final -->
    <div class="mt-6 text-center">
      <h2 class="text-lg font-medium text-gray-900 mb-1">
        Excellent travail toute la classe !
      </h2>
      <p class="text-sm text-gray-600">
        Continuez comme ça, vos textes sont superbes !
      </p>
    </div>
    </div>
  </div>

  <!-- Lien vers l'admin (caché par défaut, visible avec une combinaison de touches) -->
  <div id="adminLink" class="fixed bottom-12 right-4 hidden">
    <a href="/admin" class="bg-gray-100 text-gray-600 px-2.5 py-1 rounded text-xs font-medium hover:bg-gray-200 hover:text-gray-800 transition-all duration-150">
      🔐 Admin
    </a>
  </div>
</BaseLayout>

<script>
  // Les fonctions Firebase sont chargées globalement via BaseLayout

  // Raccourci clavier pour afficher le lien admin (Ctrl+Shift+A)
  let adminKeyPressed = {};
  document.addEventListener('keydown', (e) => {
    adminKeyPressed[e.key] = true;
    if (adminKeyPressed['Control'] && adminKeyPressed['Shift'] && adminKeyPressed['a']) {
      document.getElementById('adminLink').classList.remove('hidden');
    }
  });

  document.addEventListener('keyup', (e) => {
    adminKeyPressed[e.key] = false;
  });

  // Charger les données au chargement de la page
  document.addEventListener('DOMContentLoaded', async () => {
    // Attendre que Firebase soit initialisé
    function waitForFirebase() {
      if (typeof window.getDefiActuel === 'undefined') {
        setTimeout(waitForFirebase, 100);
        return;
      }
      
      Promise.all([
        loadDefi(),
        loadTextes()
      ]);
    }
    
    waitForFirebase();
  });

  async function loadDefi() {
    try {
      const defi = await window.getDefiActuel();
      const section = document.getElementById('defiSection');
      const texte = document.getElementById('defiTexte');
      
      if (defi && defi.texte) {
        texte.textContent = defi.texte;
        section.classList.remove('hidden');
      }
    } catch (error) {
      console.error('Erreur lors du chargement du défi:', error);
    }
  }

  async function loadTextes() {
    try {
      const textes = await window.getTextesVisibles();
      const container = document.getElementById('textesContainer');
      
      if (textes.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8">
            <p class="text-sm text-gray-500">Aucun texte publié pour le moment</p>
            <p class="text-xs text-gray-400 mt-1">Revenez bientôt pour découvrir les productions de la classe !</p>
          </div>
        `;
        return;
      }

      // Grouper les textes par groupe
      const textesParGroupe = {};
      textes.forEach(texte => {
        if (!textesParGroupe[texte.groupeNom]) {
          textesParGroupe[texte.groupeNom] = [];
        }
        textesParGroupe[texte.groupeNom].push(texte);
      });

      // Générer le HTML
      container.innerHTML = Object.entries(textesParGroupe).map(([groupeNom, textesDuGroupe]) => {
        return `
          <div class="bg-white border border-gray-200 rounded-lg p-4">
            <h3 class="text-base font-medium text-gray-900 mb-3">${groupeNom}</h3>
            <div class="space-y-3">
              ${textesDuGroupe.map(texte => `
                <div class="border border-gray-100 rounded-md p-3">
                  <div class="flex items-start justify-between mb-2">
                    <div class="flex-1">
                      <h4 class="text-sm font-medium text-gray-900 mb-1">${texte.titre}</h4>
                      <p class="text-xs text-gray-500 mb-2">${texte.type}</p>
                      <div class="text-sm text-gray-700 prose prose-sm max-w-none">
                        ${texte.contenu.length > 200 ? texte.contenu.substring(0, 200) + '...' : texte.contenu}
                      </div>
                    </div>
                    <div class="ml-3">
                      ${texte.badges && texte.badges.length > 0 ? `
                        <div class="flex gap-1">
                          ${texte.badges.map(badge => `<span class="text-xs">${badge}</span>`).join('')}
                        </div>
                      ` : ''}
                    </div>
                  </div>
                  <div class="text-xs text-gray-400">
                    Créé le ${new Date(texte.createdAt?.toDate?.() || texte.createdAt).toLocaleDateString('fr-FR')}
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
        `;
      }).join('');
      
    } catch (error) {
      console.error('Erreur lors du chargement des textes:', error);
      document.getElementById('textesContainer').innerHTML = `
        <div class="text-center py-8">
          <p class="text-sm text-gray-500">Erreur lors du chargement des textes</p>
        </div>
      `;
    }
  }
</script>