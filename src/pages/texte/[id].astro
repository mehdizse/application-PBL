---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { id } = Astro.params;
---

<BaseLayout>
  <div class="min-h-screen bg-gradient-to-b from-indigo-50/50 to-white pt-16">
    <div class="max-w-3xl mx-auto px-4 py-6">
      <button
        onclick="history.back()"
        class="mb-8 bg-white border border-gray-200 rounded-xl shadow-sm px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
      >
        <span class="mr-2">&larr;</span>
        Retour aux productions
      </button>

      <div id="texteContainer" class="space-y-6">
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 text-center">
          <p class="text-gray-600 font-medium">Chargement du texte...</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function cleanupContent(content, groupeNom) {
    return String(content || '')
      .split('\n')
      .map((line) =>
        line
          .replace(/^Excellent travail.*!$/gm, '')
          .replace(/^Très bon travail.*!$/gm, '')
          .replace(new RegExp(`^${groupeNom}$`, 'gm'), '')
      )
      .join('\n')
      .trim();
  }

  async function waitForFirebase() {
    if (typeof window.getTexte === 'undefined') {
      await new Promise((resolve) => setTimeout(resolve, 80));
      return waitForFirebase();
    }
    return null;
  }

  document.addEventListener('DOMContentLoaded', async () => {
    await waitForFirebase();
    await loadTexte();
  });

  async function loadTexte() {
    const container = document.getElementById('texteContainer');

    try {
      const texteId = window.location.pathname.split('/').pop();

      if (!texteId || texteId === 'undefined') {
        container.innerHTML = `
          <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 text-center">
            <p class="text-gray-600 font-medium">Texte non trouvé</p>
          </div>
        `;
        return;
      }

      const texte = await window.getTexte(texteId);
      if (!texte) {
        container.innerHTML = `
          <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 text-center">
            <p class="text-gray-600 font-medium">Texte non trouvé</p>
            <p class="text-gray-500 text-sm mt-2">Ce texte n'est pas encore disponible.</p>
          </div>
        `;
        return;
      }

      const badgesMap = {
        '⭐': 'Texte de la semaine',
        '🏆': 'Meilleure introduction',
        '🔗': 'Bon usage des connecteurs',
        '✍️': 'Texte bien rédigé',
        '🤝': 'Bon travail de groupe'
      };

      const cleanedContent = cleanupContent(texte.contenu, texte.groupeNom);
      const remarque = String(texte.remarqueEnseignant || '').trim();

      container.innerHTML = `
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 space-y-4">
          <div class="flex items-center justify-between gap-2">
            <span class="inline-flex items-center rounded-full border border-gray-200 px-3 py-1 text-xs font-medium bg-gray-50 text-gray-700">
              ${escapeHtml(texte.groupeNom)}
            </span>
            <span class="text-xs text-gray-500">${escapeHtml(texte.type || '')}</span>
          </div>

          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 break-words" style="overflow-wrap:anywhere;">
            ${escapeHtml(texte.titre)}
          </h1>

          ${Array.isArray(texte.badges) && texte.badges.length > 0 ? `
            <div class="flex flex-wrap gap-2">
              ${texte.badges.map((badge) => `
                <span class="px-2 py-1 rounded-full bg-gray-100 text-sm text-gray-700" title="${escapeHtml(badge)}">
                  ${escapeHtml(badgesMap[badge] || badge)}
                </span>
              `).join('')}
            </div>
          ` : ''}
        </div>

        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 leading-relaxed whitespace-pre-line text-gray-800" style="overflow-wrap:anywhere;">
          ${escapeHtml(cleanedContent)}
        </div>

        ${remarque ? `
          <div class="bg-indigo-50 border border-indigo-200 rounded-2xl p-5 shadow-sm">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center">💬</span>
              <p class="text-sm font-semibold text-indigo-900">Remarque de l'enseignant</p>
            </div>
            <p class="text-sm text-indigo-900 whitespace-pre-line">${escapeHtml(remarque)}</p>
          </div>
        ` : ''}
      `;
    } catch (error) {
      console.error('Erreur lors du chargement du texte:', error);
      container.innerHTML = `
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 text-center">
          <p class="text-red-500 font-medium">Petit problème technique...</p>
          <p class="text-gray-500 text-sm mt-2">Réessaie dans quelques instants.</p>
        </div>
      `;
    }
  }
</script>
