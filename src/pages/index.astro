---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Contenu principal mobile-first -->
  <div class="min-h-screen bg-gradient-to-b from-indigo-50/50 to-white pt-16">
    <div class="max-w-md mx-auto px-4 py-6 md:max-w-3xl">
      
      <!-- Hero / Titre -->
      <div class="text-center mb-8 px-4 py-6 bg-gradient-to-r from-indigo-50 to-white rounded-2xl">
        <div class="text-2xl mb-2">📝</div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Le Mur des Textes</h1>
        <p class="text-sm text-gray-600">Découvrez les créations de la classe ✨</p>
      </div>
      <!-- Cartes de textes -->
      <div id="textesContainer" class="space-y-4 mb-8">
        <div class="text-center py-8">
          <div class="text-2xl mb-2">📚</div>
          <p class="text-sm text-gray-600">Chargement des textes...</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Lien vers l'admin (caché par défaut) -->
  <div id="adminLink" class="fixed bottom-12 right-4 hidden">
    <a href="/admin" class="bg-indigo-600 text-white px-3 py-2 rounded-lg text-xs font-medium hover:bg-indigo-700 transition-colors">
      Espace enseignant
    </a>
  </div>
</BaseLayout>

<script>
  // Les fonctions Firebase sont chargées globalement via BaseLayout

  // Raccourci clavier pour afficher le lien admin (Ctrl+Shift+A)
  let adminKeyPressed = {};
  document.addEventListener('keydown', (e) => {
    adminKeyPressed[e.key] = true;
    if (adminKeyPressed['Control'] && adminKeyPressed['Shift'] && adminKeyPressed['a']) {
      document.getElementById('adminLink').classList.remove('hidden');
    }
  });

  document.addEventListener('keyup', (e) => {
    adminKeyPressed[e.key] = false;
  });

  // Charger les données au chargement de la page
  document.addEventListener('DOMContentLoaded', async () => {
    // Attendre que Firebase soit initialisé
    function waitForFirebase() {
      if (typeof window.getWeeklyExpressionsData === 'undefined') {
        setTimeout(waitForFirebase, 100);
        return;
      }
      
      Promise.all([
        loadTextes()
      ]);
    }
    
    waitForFirebase();
  });

    let weeklyCache = null;

  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function renderExpressionsAsList(expressions) {
    return expressions
      .map((expression) => `
        <li class="text-sm text-gray-700 leading-relaxed break-words overflow-hidden flex items-start">
          <span class="text-indigo-500 mr-2 mt-0.5">•</span>
          <span>${escapeHtml(expression)}</span>
        </li>
      `)
      .join('');
  }

  function formatIsoDateFr(isoDate) {
    const raw = String(isoDate || '').trim();
    const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(raw);
    if (!match) return raw;
    const [, year, month, day] = match;
    const date = new Date(Date.UTC(Number(year), Number(month) - 1, Number(day)));
    return new Intl.DateTimeFormat('fr-FR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
      timeZone: 'UTC'
    }).format(date);
  }

  async function loadTextes() {
    try {
      const container = document.getElementById('textesContainer');
      if (!weeklyCache?.weeks?.length) {
        weeklyCache = await window.getWeeklyExpressionsData();
      }

      const [allTextes, allGroupes] = await Promise.all([
        window.getTextes(),
        window.getGroupes()
      ]);

      const groupesVisibles = allGroupes.filter((groupe) => groupe.visible);
      const groupesVisiblesNoms = new Set(groupesVisibles.map((groupe) => groupe.nom));
      const textesVisibles = allTextes.filter((texte) => {
        const texteVisible = texte.visible;
        const groupeVisible = groupesVisiblesNoms.has(texte.groupeNom);
        return texteVisible && groupeVisible;
      });

      const fallbackWeekId = (typeof window.getIsoWeekInfo === 'function')
        ? window.getIsoWeekInfo(new Date()).weekId
        : '1970-01';

      const textesParSemaine = textesVisibles.reduce((acc, texte) => {
        const cleanWeekId = String(texte.weekId || '').trim();
        const weekId = cleanWeekId || fallbackWeekId;
        if (!acc[weekId]) acc[weekId] = [];
        acc[weekId].push(texte);
        return acc;
      }, {});

      const weeks = Array.isArray(weeklyCache?.weeks) ? weeklyCache.weeks : [];
      if (weeks.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8">
            <p class="text-sm text-gray-600">Aucune semaine disponible</p>
          </div>
        `;
        return;
      }

      const badgesMap = {
        '⭐': 'Texte de la semaine',
        '🏆': 'Meilleure introduction',
        '🔗': 'Connecteurs bien utilises',
        '✍️': 'Texte bien redige',
        '🤝': 'Bon travail de groupe'
      };

      const accentColors = ['indigo', 'emerald', 'amber', 'rose', 'purple'];
      const currentWeekId = String(weeklyCache?.currentWeek?.weekId || '').trim();
      let html = `
        <div class="relative pl-8">
          <div class="absolute left-3 top-0 bottom-0 w-px bg-indigo-200" aria-hidden="true"></div>
      `;

      weeks.forEach((week, weekIndex) => {
        const isCurrentWeek = week.weekId === currentWeekId;
        const dotClass = isCurrentWeek
          ? 'bg-indigo-600 border-4 border-white shadow-md'
          : 'bg-indigo-400 shadow-sm';
        const weekContainerClass = isCurrentWeek
          ? 'bg-indigo-50 border border-indigo-200 rounded-2xl shadow-sm p-4'
          : 'bg-white border border-gray-200 rounded-2xl shadow-sm p-4';
        const weekTextes = (textesParSemaine[week.weekId] || []).sort((a, b) => {
          const getTime = (value) => {
            if (value && typeof value.toDate === 'function') return value.toDate().getTime();
            const parsed = new Date(value || 0);
            return Number.isNaN(parsed.getTime()) ? 0 : parsed.getTime();
          };
          return getTime(b.createdAt) - getTime(a.createdAt);
        });
        const weekTitle = `Semaine ${week.weekId}`;
        const formattedStartDate = formatIsoDateFr(week.startDate);
        const formattedEndDate = formatIsoDateFr(week.endDate);
        html += `
          <section class="relative mb-12">
            <span class="absolute left-[8px] top-2 h-4 w-4 rounded-full ${dotClass}" aria-hidden="true"></span>
            <div class="${weekContainerClass}">
              <div class="flex items-center justify-between gap-2 mb-2">
                <h2 class="text-2xl font-bold text-indigo-800">${weekTitle}</h2>
                <div class="flex items-center gap-2">
                  ${isCurrentWeek ? '<span class="bg-green-50 text-green-700 rounded-full px-2 py-1 text-xs">Semaine courante</span>' : ''}
                  <span class="bg-indigo-50 text-indigo-700 border border-indigo-200 rounded-full px-2 py-1 text-xs">${week.weekId}</span>
                </div>
              </div>
              <p class="text-sm text-gray-600 font-medium mb-3">${formattedStartDate} &ndash; ${formattedEndDate}</p>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-4">
              <p class="text-sm font-semibold text-gray-900 mb-2">Expressions de la semaine</p>
              <ul class="space-y-2 leading-relaxed">
                ${renderExpressionsAsList(week.expressions)}
              </ul>
            </div>
        `;

        if (weekTextes.length === 0) {
          html += `
            <p class="text-sm text-gray-500">Aucune production cette semaine</p>
          `;
        } else {
          html += `<div class="space-y-3">`;
          weekTextes.forEach((texte, textIndex) => {
            const accentColor = accentColors[(weekIndex + textIndex) % accentColors.length];
            const badges = Array.isArray(texte.badges) ? texte.badges : [];
            const badgesHtml = badges.length > 0
              ? badges.map((badge) => `
                  <span class="inline-flex items-center px-2 py-1 rounded-full bg-gray-100 text-xs font-medium text-gray-700" title="${escapeHtml(badge)}">
                    ${escapeHtml(badgesMap[badge] || badge)}
                  </span>
                `).join('')
              : '<span class="inline-flex items-center px-2 py-1 rounded-full bg-gray-100 text-xs font-medium text-gray-700">Aucun badge</span>';

            let extrait = String(texte.contenu || '');
            const lignes = extrait.split('\n').map((line) => line.trim()).filter(Boolean);
            extrait = lignes.slice(0, 2).join(' ');
            if (lignes.length > 2) extrait += '...';
            if (extrait.length > 120) extrait = `${extrait.slice(0, 120)}...`;

            html += `
              <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-4 hover:shadow-md transition-shadow border-l-4 border-l-${accentColor}-400">
                <div class="flex items-start justify-between mb-3">
                  <span class="inline-flex items-center rounded-full border border-gray-200 px-2 py-1 text-xs font-medium bg-${accentColor}-50 text-${accentColor}-700">
                    ${escapeHtml(texte.groupeNom || 'Groupe')}
                  </span>
                  <div class="flex flex-wrap gap-1 max-w-[200px]">
                    ${badgesHtml}
                  </div>
                </div>
                <h3 class="text-base font-semibold text-gray-900 mb-1 break-words overflow-hidden">
                  ${escapeHtml(texte.titre || 'Sans titre')}
                </h3>
                <p class="text-xs text-gray-500 mb-2">${escapeHtml(texte.type || '')}</p>
                <p class="text-sm text-gray-700 mb-3 leading-relaxed break-words overflow-hidden line-clamp-2">
                  ${escapeHtml(extrait)}
                </p>
                <button 
                  onclick="window.location.href='/texte/${texte.id}'"
                  class="w-full bg-gradient-to-r from-indigo-500 to-indigo-600 text-white font-medium py-3 px-4 rounded-xl text-sm hover:from-indigo-600 hover:to-indigo-700 transition-all min-h-[44px] shadow-sm"
                >
                  Lire le texte
                </button>
              </div>
            `;
          });
          html += `</div>`;
        }

        html += `
            </div>
          </section>
        `;
      });

      html += `</div>`;
      container.innerHTML = html;
    } catch (error) {
      console.error('Erreur lors du chargement des textes:', error);
      document.getElementById('textesContainer').classList.remove('hidden');
      document.getElementById('textesContainer').innerHTML = `
        <div class="text-center py-8">
          <div class="text-2xl mb-2">😅</div>
          <p class="text-sm text-gray-600">Petit problème technique...</p>
          <p class="text-xs text-gray-500 mt-1">Réessaie dans quelques instants !</p>
        </div>
      `;
    }
  }
</script>


