---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Contenu principal mobile-first -->
  <div class="min-h-screen bg-gradient-to-b from-indigo-50/50 to-white pt-16">
    <div class="max-w-md mx-auto px-4 py-6 md:max-w-3xl">
      
      <!-- Hero / Titre -->
      <div class="text-center mb-8 px-4 py-6 bg-gradient-to-r from-indigo-50 to-white rounded-2xl">
        <div class="text-2xl mb-2">📝</div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Le Mur des Textes</h1>
        <p class="text-sm text-gray-600">Découvrez les créations de la classe ✨</p>
      </div>
      <!-- Défi de la semaine -->
      <div id="defiSection" class="hidden mb-6">
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-4">
          <div class="flex items-center mb-2">
            <span class="text-lg mr-2">🎯</span>
            <span class="text-sm font-medium text-gray-900">Défi de la semaine</span>
          </div>
          <p id="defiTexte" class="text-sm text-gray-700 leading-relaxed break-words overflow-hidden"></p>
        </div>
      </div>

      
      <!-- Cartes de textes -->
      <div id="textesContainer" class="space-y-4 mb-8">
        <div class="text-center py-8">
          <div class="text-2xl mb-2">📚</div>
          <p class="text-sm text-gray-600">Chargement des textes...</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Lien vers l'admin (caché par défaut) -->
  <div id="adminLink" class="fixed bottom-12 right-4 hidden">
    <a href="/admin" class="bg-indigo-600 text-white px-3 py-2 rounded-lg text-xs font-medium hover:bg-indigo-700 transition-colors">
      Espace enseignant
    </a>
  </div>
</BaseLayout>

<script>
  // Les fonctions Firebase sont chargées globalement via BaseLayout

  // Raccourci clavier pour afficher le lien admin (Ctrl+Shift+A)
  let adminKeyPressed = {};
  document.addEventListener('keydown', (e) => {
    adminKeyPressed[e.key] = true;
    if (adminKeyPressed['Control'] && adminKeyPressed['Shift'] && adminKeyPressed['a']) {
      document.getElementById('adminLink').classList.remove('hidden');
    }
  });

  document.addEventListener('keyup', (e) => {
    adminKeyPressed[e.key] = false;
  });

  // Charger les données au chargement de la page
  document.addEventListener('DOMContentLoaded', async () => {
    // Attendre que Firebase soit initialisé
    function waitForFirebase() {
      if (typeof window.getDefiActuel === 'undefined') {
        setTimeout(waitForFirebase, 100);
        return;
      }
      
      Promise.all([
        loadDefi(),
        loadTextes()
      ]);
    }
    
    waitForFirebase();
  });

  async function loadDefi() {
    try {
      const defi = await window.getDefiActuel();
      const section = document.getElementById('defiSection');
      const texte = document.getElementById('defiTexte');
      
      if (defi && defi.texte) {
        texte.innerHTML = defi.texte.replace(/\n/g, '<br>');
        section.classList.remove('hidden');
      }
    } catch (error) {
      console.error('Erreur lors du chargement du défi:', error);
    }
  }

  async function loadTextes() {
    try {
      // Charger TOUS les textes et les groupes
      const [allTextes, allGroupes] = await Promise.all([
        window.getTextes(), // Utiliser getTextes() au lieu de getTextesVisibles()
        window.getGroupes()
      ]);
      
      console.log('📊 Debug - Tous les textes:', allTextes.length);
      console.log('👥 Debug - Tous les groupes:', allGroupes.length);
      
      // Filtrer les groupes visibles
      const groupesVisibles = allGroupes.filter(groupe => groupe.visible);
      const groupesVisiblesNoms = new Set(groupesVisibles.map(groupe => groupe.nom));
      
      // Filtrer: textes visibles ET des groupes visibles
      const textes = allTextes.filter(texte => {
        const texteVisible = texte.visible;
        const groupeVisible = groupesVisiblesNoms.has(texte.groupeNom);
        
        if (!texteVisible) {
          console.log(`❌ Texte "${texte.titre}" masqué (texte non visible)`);
        }
        if (!groupeVisible) {
          console.log(`❌ Texte "${texte.titre}" masqué (groupe "${texte.groupeNom}" non visible)`);
        }
        
        return texteVisible && groupeVisible;
      });
      
      const container = document.getElementById('textesContainer');
      
      if (textes.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8">
            <div class="text-2xl mb-2">📝</div>
            <p class="text-sm text-gray-600">Aucun texte publié pour le moment</p>
            <p class="text-xs text-gray-500 mt-1">Reviens bientôt pour découvrir les productions de la classe !</p>
          </div>
        `;
        return;
      }

      // Regrouper par groupe
      const groupes = {};
      textes.forEach(texte => {
        if (!groupes[texte.groupeNom]) {
          groupes[texte.groupeNom] = [];
        }
        groupes[texte.groupeNom].push(texte);
      });

      // Générer le HTML pour chaque groupe
      let html = '';
      let isFirstGroup = true;
      Object.keys(groupes).forEach(groupeNom => {
        // Couleur d'accent selon le groupe
        const accentColors = ['indigo', 'emerald', 'amber', 'rose', 'purple'];
        const accentColor = accentColors[Object.keys(groupes).indexOf(groupeNom) % accentColors.length];
        
        // Séparateur pour les groupes (sauf le premier)
        if (!isFirstGroup) {
          html += `
            <div class="flex items-center my-6">
              <div class="flex-1 border-t border-gray-200"></div>
              <div class="px-3 py-1 bg-gray-50 border border-gray-200 rounded-full">
                <span class="text-xs font-medium text-gray-500">${groupeNom}</span>
              </div>
              <div class="flex-1 border-t border-gray-200"></div>
            </div>
          `;
        }
        isFirstGroup = false;
        
        html += `
          <div class="mb-6">
            <div class="space-y-3">
        `;
        
        groupes[groupeNom].forEach(texte => {
          // Badges avec texte explicatif
          const badgesMap = {
            '⭐': 'Texte de la semaine',
            '🏆': 'Meilleure introduction',
            '🔗': 'Connecteurs bien utilisés',
            '✍️': 'Texte bien rédigé',
            '🤝': 'Bon travail de groupe'
          };
          
          let badgesHtml = '';
          if (texte.badges && texte.badges.length > 0) {
            badgesHtml = texte.badges.map(badge => 
              `<span class="inline-flex items-center px-2 py-1 rounded-full bg-gray-100 text-xs font-medium text-gray-700" title="${badge}">
                ${badgesMap[badge] || badge}
              </span>`
            ).join('');
          } else {
            badgesHtml = '<span class="inline-flex items-center px-2 py-1 rounded-full bg-gray-100 text-xs font-medium text-gray-700">🌟</span>';
          }

          // Extraire les 2 premières lignes du contenu
          let extrait = texte.contenu || '';
          let lignes = extrait.split('\n').filter(line => line.trim());
          if (lignes.length > 2) {
            extrait = lignes.slice(0, 2).join(' ') + '...';
          } else {
            extrait = lignes.join(' ');
          }
          
          // Limiter la longueur
          if (extrait.length > 120) {
            extrait = extrait.substring(0, 120) + '...';
          }

          html += `
            <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-4 hover:shadow-md transition-shadow border-l-4 border-l-${accentColor}-400">
              <!-- En-tête avec groupe et badges -->
              <div class="flex items-start justify-between mb-3">
                <span class="inline-flex items-center rounded-full border border-gray-200 px-2 py-1 text-xs font-medium bg-${accentColor}-50 text-${accentColor}-700">
                  ${groupeNom}
                </span>
                <div class="flex flex-wrap gap-1 max-w-[200px]">
                  ${badgesHtml}
                </div>
              </div>
              
              <!-- Titre -->
              <h3 class="text-base font-semibold text-gray-900 mb-1 break-words overflow-hidden">
                ${texte.titre}
              </h3>
              
              <!-- Type -->
              <p class="text-xs text-gray-500 mb-2">
                ${texte.type}
              </p>
              
              <!-- Extrait du contenu -->
              <p class="text-sm text-gray-700 mb-3 leading-relaxed break-words overflow-hidden line-clamp-2">
                ${extrait}
              </p>
              
              <!-- Bouton CTA -->
              <button 
                onclick="window.location.href='/texte/${texte.id}'"
                class="w-full bg-gradient-to-r from-indigo-500 to-indigo-600 text-white font-medium py-3 px-4 rounded-xl text-sm hover:from-indigo-600 hover:to-indigo-700 transition-all min-h-[44px] shadow-sm"
              >
                Lire le texte
              </button>
            </div>
          `;
        });
        
        html += `
            </div>
          </div>
        `;
      });

      container.innerHTML = html;
    } catch (error) {
      console.error('Erreur lors du chargement des textes:', error);
      document.getElementById('textesContainer').classList.remove('hidden');
      document.getElementById('textesContainer').innerHTML = `
        <div class="text-center py-8">
          <div class="text-2xl mb-2">😅</div>
          <p class="text-sm text-gray-600">Petit problème technique...</p>
          <p class="text-xs text-gray-500 mt-1">Réessaie dans quelques instants !</p>
        </div>
      `;
    }
  }
</script>
